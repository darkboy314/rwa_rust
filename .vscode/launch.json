{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "RWA: Single-Thread Debug",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "rwa_rust",
                    "--package",
                    "rwa_rust"
                ],
                "filter": {
                    "name": "rwa_rust",
                    "kind": "bin"
                }
            },
            "args": [
                "--workers",
                "1"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "RWA: Multi-Thread Run",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "rwa_rust",
                    "--package",
                    "rwa_rust"
                ],
                "filter": {
                    "name": "rwa_rust",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}